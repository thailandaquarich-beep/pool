# Firebase Phone Authentication (frontend web config — these values are public).
# Copy this file to `.env` and fill in from Firebase Console:
#   Project settings → General → Your apps → Web app → SDK setup and configuration.
# Then rebuild the frontend (vite build). If left empty, registration falls back to
# a server dev-OTP flow (the code is shown on screen) so the flow stays testable.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_SENDER_ID=

# IMPORTANT — in Firebase Console → Authentication → Settings → Authorized domains,
# add the domain that serves this app (localhost is already allowed for dev; add
# your Cloudflare tunnel domain — note the quick-tunnel URL changes on each restart).
